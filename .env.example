# Copy this file to .env and fill in real values. .env is gitignored.

# Backend server bind (defaults shown)
DEPOPRO_BACKEND_HOST=127.0.0.1
DEPOPRO_BACKEND_PORT=47853

# Set to 1 to enable DevTools, verbose logging, and FastAPI access logs
DEPOPRO_DEBUG=0

# Deepgram API key (required for Phase B.3 transcription)
DEEPGRAM_API_KEY=
