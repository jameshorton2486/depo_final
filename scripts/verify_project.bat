%PYTHON_BIN% -c "import base64, json, math, os, struct, subprocess, tempfile, time, urllib.request, wave; env = dict(os.environ); env['DEPO_PRO_TRANSCRIBE_MOCK'] = '1'; process = subprocess.Popen(['.\\\\.venv\\\\Scripts\\\\python.exe', '-m', 'uvicorn', 'backend.app:app', '--host', '127.0.0.1', '--port', '8765'], env=env); time.sleep(2); health = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/health').read().decode('utf-8')); db_status = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/db/status').read().decode('utf-8')); stage1 = urllib.request.urlopen('http://127.0.0.1:8765/screens/stage_1_intake.html').status; stage2 = urllib.request.urlopen('http://127.0.0.1:8765/screens/stage_2_transcripts.html').status; stage3 = urllib.request.urlopen('http://127.0.0.1:8765/screens/stage_3_workspace.html').status; stage6 = urllib.request.urlopen('http://127.0.0.1:8765/screens/stage_6_export.html').status; intake_payload = json.dumps({'pasted_text': 'DELIA GARZA\\nv.\\nHOME DEPOT U.S.A., INC.\\nCAUSE NO. 25-cv-00598-OLG\\nDate: 04/30/2026\\nTime: 1:30 PM\\nNotice of deposition of Heath Thomas\\nSteven A. Nunez\\nservice@brainspine-law.com\\nATTORNEYS FOR PLAINTIFF', 'intake_metadata': {'source_document': 'verify-intake.txt'}}).encode('utf-8'); intake_request = urllib.request.Request('http://127.0.0.1:8765/api/intake/parse', data=intake_payload, headers={'Content-Type': 'application/json'}, method='POST'); parsed = json.loads(urllib.request.urlopen(intake_request).read().decode('utf-8')); persisted = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/intake/' + str(parsed['case_id'])).read().decode('utf-8')); temp_audio = tempfile.NamedTemporaryFile(delete=False, suffix='.wav'); temp_audio.close(); wave_file = wave.open(temp_audio.name, 'wb'); wave_file.setnchannels(1); wave_file.setsampwidth(2); wave_file.setframerate(16000); frames = b''.join(struct.pack('<h', int(12000 * math.sin(2 * math.pi * 220 * (index / 16000)))) for index in range(16000 * 4)); wave_file.writeframes(frames); wave_file.close(); encoded_audio = base64.b64encode(open(temp_audio.name, 'rb').read()).decode('utf-8'); transcription_payload = json.dumps({'case_id': parsed['case_id'], 'file_name': 'verify.wav', 'file_content_base64': encoded_audio}).encode('utf-8'); transcription_request = urllib.request.Request('http://127.0.0.1:8765/api/transcribe/prerecorded', data=transcription_payload, headers={'Content-Type': 'application/json'}, method='POST'); transcription_result = json.loads(urllib.request.urlopen(transcription_request).read().decode('utf-8')); timeline = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/transcript/' + str(transcription_result['session_id']) + '/timeline').read().decode('utf-8')); queue = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/review/' + str(transcription_result['session_id']) + '/queue').read().decode('utf-8')); low_item = next(item for item in queue['items'] if item['issue_category'] == 'LOW_CONFIDENCE'); resolve_payload = json.dumps({'session_id': transcription_result['session_id'], 'review_flag_id': low_item['id'], 'action': 'resolve', 'reviewer': 'verify-user', 'note': 'apply deterministic cleanup', 'apply_deterministic_rules': True}).encode('utf-8'); resolve_request = urllib.request.Request('http://127.0.0.1:8765/api/review/resolve', data=resolve_payload, headers={'Content-Type': 'application/json'}, method='POST'); resolved = json.loads(urllib.request.urlopen(resolve_request).read().decode('utf-8')); speaker_item = next(item for item in queue['items'] if item.get('speaker_segment_id') is not None); speaker_payload = json.dumps({'session_id': transcription_result['session_id'], 'review_flag_id': speaker_item['id'], 'action': 'resolve', 'reviewer': 'verify-user', 'note': 'correct speaker label', 'corrected_speaker_label': 'MS. FLORA', 'corrected_role': 'attorney'}).encode('utf-8'); speaker_request = urllib.request.Request('http://127.0.0.1:8765/api/review/resolve', data=speaker_payload, headers={'Content-Type': 'application/json'}, method='POST'); speaker_resolved = json.loads(urllib.request.urlopen(speaker_request).read().decode('utf-8')); audit = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/review/' + str(transcription_result['session_id']) + '/audit').read().decode('utf-8')); word_id = timeline['timeline'][0]['words'][0]['id']; word = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/transcript/' + str(transcription_result['session_id']) + '/word/' + str(word_id)).read().decode('utf-8')); media_status = urllib.request.urlopen('http://127.0.0.1:8765/api/transcript/' + str(transcription_result['session_id']) + '/media').status; docx_payload = json.dumps({'session_id': transcription_result['session_id'], 'include_pdf': False}).encode('utf-8'); docx_request = urllib.request.Request('http://127.0.0.1:8765/api/export/docx', data=docx_payload, headers={'Content-Type': 'application/json'}, method='POST'); docx_result = json.loads(urllib.request.urlopen(docx_request).read().decode('utf-8')); txt_payload = json.dumps({'session_id': transcription_result['session_id']}).encode('utf-8'); txt_request = urllib.request.Request('http://127.0.0.1:8765/api/export/txt', data=txt_payload, headers={'Content-Type': 'application/json'}, method='POST'); txt_result = json.loads(urllib.request.urlopen(txt_request).read().decode('utf-8')); package_payload = json.dumps({'session_id': transcription_result['session_id'], 'include_pdf': True}).encode('utf-8'); package_request = urllib.request.Request('http://127.0.0.1:8765/api/export/package', data=package_payload, headers={'Content-Type': 'application/json'}, method='POST'); package_result = json.loads(urllib.request.urlopen(package_request).read().decode('utf-8')); export_history = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/export/' + str(transcription_result['session_id']) + '/history').read().decode('utf-8')); realtime_payload = json.dumps({'session_id': transcription_result['session_id'], 'meeting_id': 'verify-meeting', 'passcode': 'verify-passcode', 'mock': True}).encode('utf-8'); realtime_request = urllib.request.Request('http://127.0.0.1:8765/api/realtime/start', data=realtime_payload, headers={'Content-Type': 'application/json'}, method='POST'); realtime_started = json.loads(urllib.request.urlopen(realtime_request).read().decode('utf-8')); time.sleep(1); realtime_status = json.loads(urllib.request.urlopen('http://127.0.0.1:8765/api/realtime/status/' + str(transcription_result['session_id'])).read().decode('utf-8')); stop_payload = json.dumps({'session_id': transcription_result['session_id'], 'reason': 'verify-stop'}).encode('utf-8'); stop_request = urllib.request.Request('http://127.0.0.1:8765/api/realtime/stop', data=stop_payload, headers={'Content-Type': 'application/json'}, method='POST'); realtime_stopped = json.loads(urllib.request.urlopen(stop_request).read().decode('utf-8')); process.terminate(); process.wait(timeout=10); assert health['status'] == 'ok'; assert db_status['database'] == 'connected'; assert db_status['tables_initialized'] is True; assert stage1 == 200; assert stage2 == 200; assert stage3 == 200; assert stage6 == 200; assert parsed['keyterms']['term_count'] >= 1; assert parsed['phonetics']['generated'] is not None; assert persisted['case']['id'] == parsed['case_id']; assert timeline['timeline']; assert queue['items']; assert resolved['review_flag']['status'] == 'reviewed'; assert speaker_resolved['speaker_correction']['corrected_speaker_label'] == 'MS. FLORA'; assert audit['items']; assert word['seek_time'] == word['start_time']; assert media_status == 200; assert any(path.endswith('.docx') for path in docx_result['files']); assert any(path.endswith('.txt') for path in txt_result['files']); assert any(path.endswith('.zip') for path in package_result['files']); assert export_history['items']; assert realtime_started['source_label'] == 'zoom_rtms'; assert realtime_status['packet_count'] >= 1; assert realtime_stopped['stream_status'] in {'completed', 'stopped'}; print(health); print(db_status); print(transcription_result['session_id'])"
